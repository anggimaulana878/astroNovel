---
import type { NovelMetadata } from '../types/novel';

interface Props {
  novels: NovelMetadata[];
}

const { novels } = Astro.props;
---

<h2 class="font-label-caps text-on-surface-variant mb-md uppercase tracking-wider" id="last-read-label" hidden>Continue Reading</h2>
<section class="bg-surface-container rounded-xl p-md flex items-center gap-md border border-outline-variant/20" id="last-read-card" hidden aria-live="polite">
  <a class="flex-shrink-0 w-16 h-20 rounded-md overflow-hidden bg-surface-container-high" id="last-read-cover" href="#" aria-hidden="true" tabindex="-1">
    <img id="last-read-cover-image" src="" alt="" class="w-full h-full object-cover" />
  </a>
  <div class="flex-1 min-w-0">
    <a class="font-title-sm text-on-surface truncate no-underline" id="last-read-title" href="#"></a>
    <p class="text-caption text-on-surface-variant" id="last-read-progress"></p>
  </div>
  <a class="bg-primary text-on-primary-fixed px-4 py-2 rounded-full flex items-center gap-2 active:scale-95 transition-transform flex-shrink-0" id="last-read-continue" href="#">
    <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">play_arrow</span>
    <span class="font-label-caps">Resume</span>
  </a>

  <script
    type="application/json"
    id="last-read-novel-seeds"
    set:html={JSON.stringify(novels.map((novel) => ({
      slug: novel.slug,
      title: novel.title,
      coverImage: novel.coverImage,
      totalChapters: novel.totalChapters,
    })))}
  ></script>
</section>

<script>
  interface StoredNovelProgress {
    chapterId: number;
    wordOffset?: number;
    lastUpdated: number;
  }

  interface LastReadCardData {
    slug: string;
    title: string;
    coverImage: string;
    resumeUrl: string;
    lastChapter: number;
    lastUpdated: number;
  }

  function parseNovelSeeds(): Array<{ slug: string; title: string; coverImage: string; totalChapters: number }> {
    const el = document.getElementById('last-read-novel-seeds');
    if (!el) return [];
    try {
      return JSON.parse(el.textContent || '[]');
    } catch {
      return [];
    }
  }

  function buildLastReadCardData(context: {
    novelSeeds: Array<{ slug: string; title: string; coverImage: string; totalChapters: number }>;
    preferences: unknown;
  }): LastReadCardData | null {
    const { novelSeeds } = context;

    if (novelSeeds.length === 0) {
      return null;
    }

    const seedMap = new Map(novelSeeds.map((seed) => [seed.slug, seed]));

    let bestEntry: { slug: string; progress: StoredNovelProgress } | null = null;

    for (const seed of novelSeeds) {
      const key = `novel-progress-${seed.slug}`;
      try {
        const raw = localStorage.getItem(key);
        if (!raw) continue;
        const progress = JSON.parse(raw) as StoredNovelProgress;

        if (!bestEntry || progress.lastUpdated > bestEntry.progress.lastUpdated) {
          bestEntry = { slug: seed.slug, progress };
        }
      } catch {
        continue;
      }
    }

    if (!bestEntry) return null;

    const seed = seedMap.get(bestEntry.slug);
    if (!seed) return null;

    return {
      slug: seed.slug,
      title: seed.title,
      coverImage: seed.coverImage,
      resumeUrl: `/novels/${seed.slug}/read?chapter=${bestEntry.progress.chapterId}`,
      lastChapter: bestEntry.progress.chapterId,
      lastUpdated: bestEntry.progress.lastUpdated,
    };
  }

  const card = document.getElementById('last-read-card');
  const label = document.getElementById('last-read-label');
  const coverLink = document.getElementById('last-read-cover') as HTMLAnchorElement | null;
  const coverImage = coverLink?.querySelector('img') as HTMLImageElement | null;
  const titleLink = document.getElementById('last-read-title') as HTMLAnchorElement | null;
  const progressText = document.getElementById('last-read-progress') as HTMLParagraphElement | null;
  const continueLink = document.getElementById('last-read-continue') as HTMLAnchorElement | null;

  if (!card || !coverLink || !coverImage || !titleLink || !progressText || !continueLink) {
    console.error('[LastReadCard] Required elements not found');
  } else {
    const data = buildLastReadCardData({
      novelSeeds: parseNovelSeeds(),
      preferences: null,
    });

    if (data) {
      coverLink.href = data.resumeUrl;
      titleLink.href = data.resumeUrl;
      continueLink.href = data.resumeUrl;
      coverImage.src = data.coverImage;
      coverImage.alt = `${data.title} cover`;
      titleLink.textContent = data.title;
      progressText.textContent = `Chapter ${data.lastChapter}`;
      card.hidden = false;
      if (label) label.hidden = false;
    }
  }
</script>
