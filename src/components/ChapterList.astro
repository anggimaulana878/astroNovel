---
import type { Chapter } from '../types/novel';

interface Props {
  chapters: Chapter[];
  novelSlug: string;
}

const { chapters, novelSlug } = Astro.props;

const chapterGroups: { label: string; chapters: Chapter[] }[] = [];
for (let i = 0; i < chapters.length; i += 100) {
  const start = i + 1;
  const end = Math.min(i + 100, chapters.length);
  chapterGroups.push({
    label: `${start} - ${end}`,
    chapters: chapters.slice(i, i + 100)
  });
}

const reversedChapters = [...chapters].reverse();
const reversedGroups: { label: string; chapters: Chapter[] }[] = [];
for (let i = 0; i < reversedChapters.length; i += 100) {
  const start = reversedChapters.length - i;
  const end = Math.max(reversedChapters.length - i - 99, 1);
  reversedGroups.push({
    label: `${end} - ${start}`,
    chapters: reversedChapters.slice(i, i + 100)
  });
}
---

<section class="mt-8 border-t border-outline-variant/10">
  <div class="px-container-margin py-4">
    <h3 class="font-bold text-on-surface text-lg">Chapters</h3>
  </div>

  <div class="flex overflow-x-auto no-scrollbar border-b border-outline-variant/10">
    {chapterGroups.map((group, index) => (
      <button
        class={`flex-none px-6 py-3 text-center font-bold whitespace-nowrap transition-all ${
          index === 0
            ? 'text-primary border-b-2 border-primary'
            : 'text-on-surface-variant hover:text-on-surface'
        }`}
        data-tab={index}
        id={`btn-batch-${index}`}
      >
        {group.label}
      </button>
    ))}
  </div>

  <div class="animate-in fade-in duration-300" id="chapters-container">
    <div class="flex justify-between items-center px-container-margin py-3 bg-surface-container-lowest">
      <span class="text-[10px] font-label-caps text-on-surface-variant" id="chapter-count-text">
        SHOWING {chapterGroups[0]?.chapters.length || 0} CHAPTERS ({chapterGroups[0]?.label || ''})
      </span>
    </div>

    <div class="divide-y divide-outline-variant/10" id="chapters-list">
      {chapterGroups.map((group, index) => (
        <div class={`tab-panel ${index === 0 ? '' : 'hidden'}`} data-panel={index}>
          {group.chapters.map((chapter) => (
            <a
              href={`/novels/${novelSlug}/read?chapter=${chapter.id}`}
              class="flex items-center justify-between px-container-margin py-4 hover:bg-surface-variant/30 active:bg-surface-variant/50 transition-colors"
            >
              <div class="flex flex-col">
                <span class="font-bold text-on-surface">Chapter {chapter.id}: {chapter.title}</span>
                <span class="text-[10px] text-on-surface-variant mt-1">{chapter.body ? `${Math.round(chapter.body.length / 5)} words` : ''}</span>
              </div>
              <span class="material-symbols-outlined text-on-surface-variant">chevron_right</span>
            </a>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('[data-tab]').forEach(tab => {
    tab.addEventListener('click', () => {
      const tabIndex = tab.getAttribute('data-tab');
      const countText = document.getElementById('chapter-count-text');
      const container = document.getElementById('chapters-container');

      document.querySelectorAll('[data-tab]').forEach(t => {
        t.classList.remove('text-primary', 'border-b-2', 'border-primary');
        t.classList.add('text-on-surface-variant');
      });
      tab.classList.add('text-primary', 'border-b-2', 'border-primary');
      tab.classList.remove('text-on-surface-variant');

      document.querySelectorAll('.tab-panel').forEach(p => p.classList.add('hidden'));
      document.querySelector(`[data-panel="${tabIndex}"]`)?.classList.remove('hidden');

      const label = tab.textContent?.trim() || '';
      const panels = document.querySelectorAll('.tab-panel');
      const panel = panels[Number(tabIndex)];
      const count = panel?.querySelectorAll('a').length || 0;
      if (countText) countText.textContent = `SHOWING ${count} CHAPTERS (${label})`;
    });
  });
</script>
