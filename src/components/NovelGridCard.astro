---
import type { NovelMetadata } from '../types/novel';

interface Props {
  novel: NovelMetadata;
  rating?: number;
  authorDisplay?: string;
}

const { novel, rating = 4.5, authorDisplay } = Astro.props;
---

<a href={`/novels/${novel.slug}`}>
  <div class="flex flex-col gap-2 group cursor-pointer">
    <div class="relative aspect-[3/4] rounded-xl overflow-hidden bg-[#2a2a2c] transition-transform duration-300 group-hover:scale-[1.02]">
      <img src={novel.coverImage} alt={novel.title + ' cover'} class="w-full h-full object-cover" />
      <div class="absolute top-2 right-2 bg-black/60 backdrop-blur-md px-1.5 py-0.5 rounded-md flex items-center gap-0.5">
        <span class="material-symbols-outlined text-[10px] text-[#d0bcff]" style="font-variation-settings: 'FILL' 1;">star</span>
        <span class="text-[10px] font-bold text-white">{rating}</span>
      </div>
    </div>
    <div>
      <h3 class="text-[14px] font-semibold leading-tight text-[#e5e1e4] line-clamp-2">{novel.title}</h3>
      <p class="text-[12px] text-[#8A8A93] mt-1">{authorDisplay || novel.author} • Ch. {novel.totalChapters}</p>
    </div>
  </div>
</a>
