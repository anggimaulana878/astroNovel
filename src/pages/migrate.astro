---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
---

<Layout title="Migration Tool — RuangBaca" description="Migrate raw novel data to production format">

<!-- Decorative background glows -->
<div class="fixed top-0 left-0 w-[400px] h-[400px] bg-primary/10 rounded-full blur-[120px] pointer-events-none -z-10"></div>
<div class="fixed bottom-0 right-0 w-[400px] h-[400px] bg-secondary-container/10 rounded-full blur-[120px] pointer-events-none -z-10"></div>

<!-- Top App Bar -->
<header class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-xl border-b border-outline-variant/20 flex items-center px-container-margin h-16">
  <div class="max-w-[680px] mx-auto w-full flex items-center gap-md">
    <a href="/" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors">
      <span class="material-symbols-outlined text-on-surface-variant">arrow_back</span>
    </a>
    <h1 class="font-headline-md text-on-surface">Migration Tool</h1>
  </div>
</header>

<main class="pt-20 pb-16 max-w-[680px] mx-auto px-container-margin">

  <!-- Section: Available in public/raw/ -->
  <section class="mb-lg bg-surface-container-low border border-outline-variant/20 rounded-xl p-md">
    <h2 class="font-label-caps text-on-surface-variant mb-md uppercase tracking-wider">Available in public/raw/</h2>
    <ul id="novelList" class="flex flex-col gap-2">
      <li class="empty-state flex flex-col items-center justify-center py-8 text-on-surface-variant">
        <span class="material-symbols-outlined text-4xl mb-2 opacity-50">hourglass_empty</span>
        <span class="text-caption">Loading...</span>
      </li>
    </ul>
  </section>

  <!-- Section: Or Choose Folder -->
  <section class="mb-lg bg-surface-container-low border border-outline-variant/20 rounded-xl p-md">
    <h2 class="font-label-caps text-on-surface-variant mb-md uppercase tracking-wider">Or Choose Folder</h2>
    <input type="file" id="folderInput" hidden />
    <button
      id="chooseFolderBtn"
      class="w-full bg-primary text-on-primary-fixed px-md py-3 rounded-xl flex items-center justify-center gap-2 active:scale-[0.98] transition-transform font-label-caps"
    >
      <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">folder_open</span>
      <span>Choose Folder...</span>
    </button>
    <div id="chosenFolder" class="hidden mt-md p-3 rounded-lg flex items-center gap-2 text-caption"></div>
  </section>

  <!-- Section: Action -->
  <section class="mb-lg bg-surface-container-low border border-outline-variant/20 rounded-xl p-md">
    <div class="flex items-center justify-between gap-md">
      <button
        id="migrateBtn"
        disabled
        class="bg-primary text-on-primary-fixed px-5 py-3 rounded-full flex items-center gap-2 font-label-caps active:scale-95 transition-transform disabled:bg-surface-container-highest disabled:text-on-surface-variant disabled:cursor-not-allowed"
      >
        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">rocket_launch</span>
        <span>Migrate Selected</span>
      </button>
      <span id="selectionCount" class="bg-surface-container-high text-on-surface-variant font-label-caps px-3 py-1.5 rounded-full">0 selected</span>
    </div>
  </section>

  <!-- Section: Output Log -->
  <section class="mb-lg bg-surface-container-low border border-outline-variant/20 rounded-xl p-md">
    <div class="flex items-center justify-between mb-md">
      <h2 class="font-label-caps text-on-surface-variant uppercase tracking-wider">Output Log</h2>
      <button id="clearLogBtn" class="text-on-surface-variant hover:text-on-surface transition-colors">
        <span class="material-symbols-outlined text-[18px]">delete_sweep</span>
      </button>
    </div>
    <div
      id="logContainer"
      class="bg-black rounded-lg p-md max-h-[400px] overflow-y-auto custom-scrollbar font-mono text-[12px] leading-6"
    >
      <div class="log-line text-primary">$ Ready. Select novels and click Migrate.</div>
    </div>
  </section>

</main>

<style is:global>
  .custom-scrollbar::-webkit-scrollbar {
    width: 8px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: #494454;
    border-radius: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb:hover {
    background: #5a5468;
  }

  .log-line {
    white-space: pre-wrap;
    word-break: break-all;
  }
  .log-line.error { color: #ffb4ab; }
  .log-line.success { color: #a5d6a7; }
  .log-line.info { color: #d0bcff; }

  .spinner {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid #494454;
    border-top-color: #d0bcff;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
    margin-right: 0.5rem;
    vertical-align: middle;
  }
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  interface NovelEntry {
    folder: string;
    title: string;
    authors: string[];
    chapters: number;
    source: string;
  }

  interface UploadedSource {
    folder: string;
    title: string;
    chapters: number;
  }

  let novels: NovelEntry[] = [];
  let uploadedSource: UploadedSource | null = null;
  let migrating = false;

  const folderInput = document.getElementById('folderInput') as HTMLInputElement;
  folderInput.setAttribute('webkitdirectory', '');

  async function loadNovels() {
    try {
      const res = await fetch('/api/migrate/novels');
      novels = await res.json();
      renderList();
    } catch (err) {
      const list = document.getElementById('novelList')!;
      list.innerHTML = `
        <li class="flex flex-col items-center justify-center py-8 text-on-surface-variant">
          <span class="material-symbols-outlined text-4xl mb-2 opacity-50">error</span>
          <span class="text-caption">Failed to load novels</span>
        </li>
      `;
    }
  }

  function renderList() {
    const list = document.getElementById('novelList')!;
    if (novels.length === 0) {
      list.innerHTML = `
        <li class="flex flex-col items-center justify-center py-8 text-on-surface-variant">
          <span class="material-symbols-outlined text-4xl mb-2 opacity-50">folder_off</span>
          <span class="text-caption">No novels found in public/raw/</span>
        </li>
      `;
      return;
    }
    list.innerHTML = novels.map((n, i) => `
      <li class="flex items-center gap-3 p-3 rounded-lg hover:bg-surface-container-high transition-colors cursor-pointer">
        <input type="checkbox" id="novel-${i}" data-index="${i}" class="w-[18px] h-[18px] accent-primary flex-shrink-0 cursor-pointer" />
        <label class="flex-1 min-w-0 cursor-pointer" for="novel-${i}">
          <div class="text-on-surface font-medium truncate">${escapeHtml(n.title)}</div>
          <div class="text-caption text-on-surface-variant truncate mt-0.5">${n.chapters} ch · ${escapeHtml(n.authors.join(', ') || 'Unknown')} · ${escapeHtml(n.folder)}</div>
        </label>
      </li>
    `).join('');

    list.querySelectorAll('input[type="checkbox"]').forEach((cb) => {
      cb.addEventListener('change', updateSelection);
    });
  }

  function escapeHtml(s: string): string {
    const d = document.createElement('div');
    d.textContent = s;
    return d.innerHTML;
  }

  function updateSelection() {
    const checked = document.querySelectorAll('#novelList input:checked');
    const count = checked.length + (uploadedSource ? 1 : 0);
    document.getElementById('selectionCount')!.textContent = `${count} selected`;
    const btn = document.getElementById('migrateBtn') as HTMLButtonElement;
    btn.disabled = count === 0 || migrating;
  }

  const chooseFolderBtn = document.getElementById('chooseFolderBtn')!;
  chooseFolderBtn.addEventListener('click', () => folderInput.click());

  folderInput.addEventListener('change', async () => {
    const files = folderInput.files;
    if (!files || files.length === 0) return;

    const chosenDiv = document.getElementById('chosenFolder')!;
    chosenDiv.className = 'mt-md p-3 rounded-lg flex items-center gap-2 text-caption bg-surface-container-high text-on-surface-variant';
    chosenDiv.innerHTML = '<span class="spinner"></span><span>Uploading...</span>';

    const firstPath = files[0].webkitRelativePath;
    const folderName = firstPath.split('/')[0];

    const formData = new FormData();
    formData.append('folderName', folderName);

    for (const file of Array.from(files)) {
      const relativePath = file.webkitRelativePath.substring(folderName.length + 1);
      if (relativePath.endsWith('.json') || relativePath.endsWith('.jpg') || relativePath.endsWith('.png')) {
        formData.append('files', file);
        formData.append('paths', relativePath);
      }
    }

    try {
      const res = await fetch('/api/migrate/upload', {
        method: 'POST',
        body: formData,
      });
      const data = await res.json();

      if (data.uploaded) {
        uploadedSource = { folder: data.folder, title: data.folder, chapters: data.chapters };
        chosenDiv.className = 'mt-md p-3 rounded-lg flex items-center gap-2 text-caption bg-green-900/30 border border-green-700/40 text-green-400';
        chosenDiv.innerHTML = `
          <span class="material-symbols-outlined text-[18px]">check_circle</span>
          <span class="flex-1 truncate">${escapeHtml(data.folder)} — ${data.chapters} chapters (${data.files} files)</span>
          <button id="removeUploaded" class="text-red-400 hover:text-red-300 transition-colors">
            <span class="material-symbols-outlined text-[18px]">close</span>
          </button>
        `;
        document.getElementById('removeUploaded')!.addEventListener('click', () => {
          uploadedSource = null;
          chosenDiv.className = 'hidden';
          chosenDiv.innerHTML = '';
          updateSelection();
        });
        await loadNovels();
      } else {
        chosenDiv.className = 'mt-md p-3 rounded-lg flex items-center gap-2 text-caption bg-red-900/30 border border-red-700/40 text-red-400';
        chosenDiv.innerHTML = `<span class="material-symbols-outlined text-[18px]">error</span><span>${escapeHtml(data.error)}</span>`;
        uploadedSource = null;
      }
    } catch (err) {
      const message = err instanceof Error ? err.message : 'Upload failed';
      chosenDiv.className = 'mt-md p-3 rounded-lg flex items-center gap-2 text-caption bg-red-900/30 border border-red-700/40 text-red-400';
      chosenDiv.innerHTML = `<span class="material-symbols-outlined text-[18px]">error</span><span>${escapeHtml(message)}</span>`;
      uploadedSource = null;
    }

    updateSelection();
    folderInput.value = '';
  });

  document.getElementById('migrateBtn')!.addEventListener('click', async () => {
    if (migrating) return;
    migrating = true;
    const btn = document.getElementById('migrateBtn') as HTMLButtonElement;
    const originalContent = btn.innerHTML;
    btn.innerHTML = '<span class="spinner"></span><span>Migrating...</span>';
    btn.disabled = true;

    const sources: Array<{ folder: string; title?: string }> = [];
    document.querySelectorAll('#novelList input:checked').forEach((cb) => {
      const idx = parseInt((cb as HTMLInputElement).dataset.index!);
      sources.push({ folder: novels[idx].folder, title: novels[idx].title });
    });
    if (uploadedSource) {
      sources.push({ folder: uploadedSource.folder, title: uploadedSource.title });
    }

    const log = document.getElementById('logContainer')!;
    log.innerHTML = '';
    addLog(`$ Starting migration of ${sources.length} novel(s)...`, 'info');

    try {
      const res = await fetch('/api/migrate/run', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sources }),
      });
      const data = await res.json();

      for (const line of data.logs) {
        const type = line.includes('✅') || line.includes('✓')
          ? 'success'
          : line.includes('❌')
          ? 'error'
          : 'info';
        addLog(line, type);
      }

      if (data.failures === 0) {
        addLog(`\nDone! ${data.success} novel(s) migrated successfully.`, 'success');
      } else {
        addLog(`\nDone with ${data.failures} failure(s). ${data.success} succeeded.`, 'error');
      }
    } catch (err) {
      const message = err instanceof Error ? err.message : 'Request failed';
      addLog(message, 'error');
    }

    migrating = false;
    btn.innerHTML = originalContent;
    updateSelection();
  });

  document.getElementById('clearLogBtn')!.addEventListener('click', () => {
    const log = document.getElementById('logContainer')!;
    log.innerHTML = '<div class="log-line text-primary">$ Ready. Select novels and click Migrate.</div>';
  });

  function addLog(text: string, type: 'info' | 'success' | 'error' = 'info') {
    const log = document.getElementById('logContainer')!;
    const line = document.createElement('div');
    line.className = `log-line ${type}`;
    line.textContent = text;
    log.appendChild(line);
    log.scrollTop = log.scrollHeight;
  }

  loadNovels();
</script>

</Layout>
