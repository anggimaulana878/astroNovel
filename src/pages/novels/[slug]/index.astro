---
import Layout from '../../../layouts/Layout.astro';
import ChapterList from '../../../components/ChapterList.astro';
import { loadNovelMetadata, loadChapterRange } from '../../../lib/novel-loader';

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

const novel = await loadNovelMetadata(slug);
const allChapters = await loadChapterRange(slug, 1, novel.totalChapters);

const lastChapter = novel.totalChapters;
const rating = 4.5;
const genres = ['FANTASY'];
---

<Layout title={`${novel.title} - RuangBaca`} description={novel.description}>

<!-- Top App Bar -->
<header class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-xl border-b border-outline-variant/20 flex items-center justify-between px-container-margin h-16">
  <div class="flex items-center gap-4">
    <a href="/" class="active:scale-95 transition-transform hover:opacity-80">
      <span class="material-symbols-outlined text-primary">arrow_back</span>
    </a>
    <h1 class="font-headline-md text-primary truncate max-w-[200px]">{novel.title}</h1>
  </div>
  <div class="flex items-center gap-2">
    <button class="active:scale-95 transition-transform hover:opacity-80" id="delete-btn" data-slug={slug} data-title={novel.title} data-chapters={novel.totalChapters}>
      <span class="material-symbols-outlined text-primary">delete</span>
    </button>
    <button class="active:scale-95 transition-transform hover:opacity-80">
      <span class="material-symbols-outlined text-primary">share</span>
    </button>
  </div>
</header>

<main class="pt-16 pb-12">

  <!-- Hero Section -->
  <section class="relative w-full h-[320px] overflow-hidden flex items-end">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-background/60 z-10"></div>
      <img class="w-full h-full object-cover scale-110 opacity-40 blur-md" src={novel.coverImage} alt="" />
    </div>
    <div class="relative z-20 w-full px-container-margin pb-6 flex gap-md">
      <div class="shrink-0 shadow-2xl">
        <img class="w-[110px] h-[160px] object-cover rounded-xl border border-outline-variant/30" src={novel.coverImage} alt={`${novel.title} cover`} />
      </div>
      <div class="flex flex-col justify-end gap-xs overflow-hidden">
        <h2 class="font-bold text-[20px] leading-tight text-on-surface line-clamp-2">{novel.title}</h2>
        <p class="text-on-surface-variant text-sm">Author: {novel.author}</p>
        <div class="flex flex-wrap gap-xs mt-1">
          {genres.map((genre) => (
            <span class="bg-surface-variant text-on-surface-variant text-[10px] font-label-caps px-2 py-1 rounded-full border border-outline-variant/20">{genre}</span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Synopsis -->
  <section class="px-container-margin mt-6">
    <div class="text-on-surface-variant text-sm leading-relaxed line-clamp-3" id="synopsis-text">
      {novel.description}
    </div>
    <button class="mt-2 text-primary font-bold text-sm flex items-center gap-1" id="read-more-btn" onclick="toggleSynopsis()">
      Read More
      <span class="material-symbols-outlined text-sm" id="read-more-icon">expand_more</span>
    </button>
  </section>

  <!-- Stats Bar -->
  <section class="flex items-center justify-around py-md border-b border-outline-variant/10 bg-surface-container-low mx-container-margin rounded-2xl mt-6">
    <div class="flex flex-col items-center">
      <div class="flex items-center gap-1 text-on-surface">
        <span class="material-symbols-outlined text-primary text-sm">visibility</span>
        <span class="font-bold">-</span>
      </div>
      <span class="text-[10px] text-on-surface-variant font-label-caps">VIEWS</span>
    </div>
    <div class="w-[1px] h-8 bg-outline-variant/20"></div>
    <div class="flex flex-col items-center">
      <div class="flex items-center gap-1 text-on-surface">
        <span class="material-symbols-outlined text-primary text-sm" style="font-variation-settings: 'FILL' 1;">star</span>
        <span class="font-bold">{rating}</span>
      </div>
      <span class="text-[10px] text-on-surface-variant font-label-caps">RATING</span>
    </div>
    <div class="w-[1px] h-8 bg-outline-variant/20"></div>
    <div class="flex flex-col items-center">
      <div class="flex items-center gap-1 text-on-surface">
        <span class="material-symbols-outlined text-primary text-sm">menu_book</span>
        <span class="font-bold">{novel.totalChapters}</span>
      </div>
      <span class="text-[10px] text-on-surface-variant font-label-caps">CHAPTERS</span>
    </div>
  </section>

  <!-- Start Reading Button -->
  <section class="px-container-margin mt-6">
    <a href={`/novels/${slug}/read?chapter=1`} class="w-full bg-primary text-on-primary font-bold py-4 rounded-xl active:scale-95 transition-transform shadow-lg shadow-primary/20 text-center block">
      {lastChapter > 1 ? `Continue Reading - Ch. ${lastChapter}` : `Start Reading`}
    </a>
  </section>

  <!-- Chapters -->
  <ChapterList chapters={allChapters} novelSlug={slug} />

  <!-- Delete Modal -->
  <dialog id="delete-modal" class="border-none rounded-xl p-0 max-w-[500px] w-[90%] bg-surface-container text-on-surface shadow-2xl">
    <div class="p-8">
      <div id="modal-confirm">
        <h2 class="text-headline-md text-on-surface mb-4">Delete Novel</h2>
        <p class="text-on-surface-variant mb-4">
          <strong id="modal-title" class="text-on-surface"></strong><br />
          <span id="modal-chapters"></span> chapters
        </p>
        <p class="text-error text-sm mb-4">This action cannot be undone.</p>
        <label for="confirm-input" class="text-on-surface-variant text-sm block mb-2">Type the novel title to confirm:</label>
        <input type="text" id="confirm-input" class="w-full bg-surface-container-high border border-outline-variant/30 rounded-lg px-4 py-3 text-on-surface outline-none focus:border-primary" placeholder="Novel title" autocomplete="off" />
        <div class="flex gap-3 mt-6">
          <button class="flex-1 bg-surface-variant text-on-surface-variant py-3 rounded-lg font-bold" id="modal-cancel">Cancel</button>
          <button class="flex-1 bg-error text-on-error py-3 rounded-lg font-bold disabled:opacity-50 disabled:cursor-not-allowed" id="modal-delete" disabled>Delete</button>
        </div>
      </div>
      <div id="modal-loading" style="display: none;">
        <p class="text-on-surface-variant text-center">Preparing deletion...</p>
      </div>
      <div id="modal-result" style="display: none;">
        <h2 class="text-headline-md text-on-surface mb-4">Run This Command</h2>
        <p class="text-on-surface-variant mb-4">Copy and run in your terminal:</p>
        <div class="bg-surface-container-high rounded-lg p-4 flex items-center justify-between">
          <code id="command-text" class="text-primary text-sm"></code>
          <button class="text-primary text-sm font-bold ml-4" id="copy-btn">Copy</button>
        </div>
        <p class="text-on-surface-variant text-sm mt-3"><span id="file-count"></span> files</p>
        <div class="flex mt-6">
          <button class="flex-1 bg-surface-variant text-on-surface-variant py-3 rounded-lg font-bold" id="modal-close">Close</button>
        </div>
      </div>
      <div id="modal-error" style="display: none;">
        <h2 class="text-headline-md text-error mb-4">Error</h2>
        <p id="error-message" class="text-error text-sm mb-4"></p>
        <p class="text-on-surface-variant text-sm mb-4">You can run this directly:</p>
        <div class="bg-surface-container-high rounded-lg p-4 flex items-center justify-between">
          <code id="fallback-command" class="text-primary text-sm"></code>
          <button class="text-primary text-sm font-bold ml-4" id="fallback-copy-btn">Copy</button>
        </div>
        <div class="flex mt-6">
          <button class="flex-1 bg-surface-variant text-on-surface-variant py-3 rounded-lg font-bold" id="modal-error-close">Close</button>
        </div>
      </div>
    </div>
  </dialog>

  <script type="application/json" id="delete-modal-data" set:html={JSON.stringify({
    slug,
    title: novel.title,
    chapters: novel.totalChapters
  })}></script>

</main>

<style is:global>
  .line-clamp-3 {
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  function toggleSynopsis() {
    const text = document.getElementById('synopsis-text');
    const btn = document.getElementById('read-more-btn');
    if (text!.classList.contains('line-clamp-3')) {
      text!.classList.remove('line-clamp-3');
      btn!.innerHTML = 'Show Less <span class="material-symbols-outlined text-sm" id="read-more-icon">expand_less</span>';
    } else {
      text!.classList.add('line-clamp-3');
      btn!.innerHTML = 'Read More <span class="material-symbols-outlined text-sm" id="read-more-icon">expand_more</span>';
    }
  }
</script>

<script>
  const dataEl = document.getElementById('delete-modal-data');
  const { slug: novelSlug, title: novelTitle, chapters: novelChapters } = dataEl ? JSON.parse(dataEl.textContent || '{}') : { slug: '', title: '', chapters: 0 };

  const modal = document.getElementById('delete-modal') as HTMLDialogElement;
  const deleteBtn = document.getElementById('delete-btn')!;
  const confirmInput = document.getElementById('confirm-input') as HTMLInputElement;
  const modalTitle = document.getElementById('modal-title')!;
  const modalChapters = document.getElementById('modal-chapters')!;
  const modalDelete = document.getElementById('modal-delete') as HTMLButtonElement;
  const modalCancel = document.getElementById('modal-cancel')!;
  const modalClose = document.getElementById('modal-close')!;
  const commandText = document.getElementById('command-text')!;
  const fileCount = document.getElementById('file-count')!;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const modalLoading = document.getElementById('modal-loading')!;
  const modalResult = document.getElementById('modal-result')!;
  const modalConfirm = document.getElementById('modal-confirm')!;
  const modalError = document.getElementById('modal-error')!;
  const errorMessage = document.getElementById('error-message')!;
  const fallbackCommand = document.getElementById('fallback-command')!;
  const fallbackCopyBtn = document.getElementById('fallback-copy-btn') as HTMLButtonElement;
  const modalErrorClose = document.getElementById('modal-error-close')!;

  function showState(state: 'confirm' | 'loading' | 'result' | 'error') {
    (modalConfirm as HTMLElement).style.display = state === 'confirm' ? 'block' : 'none';
    (modalLoading as HTMLElement).style.display = state === 'loading' ? 'block' : 'none';
    (modalResult as HTMLElement).style.display = state === 'result' ? 'block' : 'none';
    (modalError as HTMLElement).style.display = state === 'error' ? 'block' : 'none';
  }

  function resetModal() {
    confirmInput.value = '';
    modalDelete.disabled = true;
    showState('confirm');
  }

  deleteBtn.addEventListener('click', () => {
    modalTitle.textContent = novelTitle;
    modalChapters.textContent = String(novelChapters);
    resetModal();
    modal.showModal();
  });

  confirmInput.addEventListener('input', () => {
    modalDelete.disabled = confirmInput.value !== novelTitle;
  });

  modalCancel.addEventListener('click', () => { modal.close(); });
  modalClose.addEventListener('click', () => { modal.close(); });
  modalErrorClose.addEventListener('click', () => { modal.close(); });
  modal.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });

  async function copyToClipboard(text: string, btn: HTMLButtonElement) {
    try {
      await navigator.clipboard.writeText(text);
      const original = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = original; }, 2000);
    } catch (err) { console.error('[DeleteModal] Copy failed:', err); }
  }

  copyBtn.addEventListener('click', () => { copyToClipboard(commandText.textContent!, copyBtn); });
  fallbackCopyBtn.addEventListener('click', () => { copyToClipboard(fallbackCommand.textContent!, fallbackCopyBtn); });

  modalDelete.addEventListener('click', async () => {
    showState('loading');
    try {
      const response = await fetch(`/api/novels/${novelSlug}/delete`, { method: 'DELETE' });
      const data = await response.json();
      if (!response.ok) throw new Error(data.error || 'Failed');
      const expected = `npm run delete-novel ${novelSlug}`;
      if (data.command !== expected) throw new Error('Invalid response');
      commandText.textContent = data.command;
      fileCount.textContent = `${data.files.length} files`;
      showState('result');
    } catch (err: unknown) {
      const msg = err instanceof Error ? err.message : 'Unknown error';
      errorMessage.textContent = msg;
      fallbackCommand.textContent = `npm run delete-novel ${novelSlug}`;
      showState('error');
    }
  });
</script>

</Layout>
