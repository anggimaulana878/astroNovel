---
export const prerender = false;

import { loadNovelMetadata, loadChapterRange } from '../../../lib/novel-loader';
import { getChapterBatch, getWordCountBatch, validateBatchParams, countWords } from '../../../lib/batch-calculator';
import { sanitizeChapterHTML } from '../../../lib/html-sanitizer';

const { slug } = Astro.params;
const url = Astro.url;

if (!slug) {
  return Astro.redirect('/');
}

const startParam = url.searchParams.get('start');
const modeParam = url.searchParams.get('mode') || 'chapters';
const sizeParam = url.searchParams.get('size') || '5';

const startChapter = parseInt(startParam || '1', 10);
const batchSize = parseInt(sizeParam, 10);

if (!validateBatchParams(modeParam, batchSize)) {
  return Astro.redirect(`/novels/${slug}`);
}

const novel = await loadNovelMetadata(slug);

let batchStart: number;
let batchEnd: number;
let chapters;

if (modeParam === 'chapters') {
  const batch = getChapterBatch(startChapter, batchSize, novel.totalChapters);
  batchStart = batch.start;
  batchEnd = batch.end;
  chapters = await loadChapterRange(slug, batchStart, batchEnd);
} else {
  const allChapters = await loadChapterRange(slug, startChapter, Math.min(startChapter + 50, novel.totalChapters));
  const batch = getWordCountBatch(startChapter, batchSize, allChapters);
  batchStart = batch.start;
  batchEnd = batch.end;
  chapters = allChapters.slice(0, batchEnd - batchStart + 1);
}

const totalWords = chapters.reduce((sum, ch) => sum + countWords(ch.body), 0);

const prevBatchStart = Math.max(1, batchStart - batchSize);
const nextBatchStart = Math.min(batchEnd + 1, novel.totalChapters);
const hasPrev = batchStart > 1;
const hasNext = batchEnd < novel.totalChapters;

const pageTitle = `${novel.title} - Chapters ${batchStart}-${batchEnd}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="index, follow" />
  <meta name="googlebot" content="index, follow" />
  
  <meta property="og:title" content={pageTitle} />
  <meta property="og:type" content="article" />
  <meta property="og:url" content={url.href} />
  
  <title>{pageTitle}</title>
  
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": pageTitle,
    "author": {
      "@type": "Person",
      "name": novel.author
    },
    "datePublished": novel.publishDate,
    "dateModified": new Date().toISOString(),
    "inLanguage": novel.language,
    "isAccessibleForFree": true,
    "publisher": {
      "@type": "Organization",
      "name": "AstroNovel"
    },
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["article[role='main']", "section[itemprop='articleBody']"]
    }
  })} />
  
  <style is:global>
    :root {
      --bg-primary: #ffffff;
      --bg-secondary: #f5f5f5;
      --text-primary: #1a1a1a;
      --text-secondary: #666666;
      --border: #e0e0e0;
      --accent: #3b82f6;
      --accent-hover: #2563eb;
    }

    .dark {
      --bg-primary: #1a1a1a;
      --bg-secondary: #2a2a2a;
      --text-primary: #e0e0e0;
      --text-secondary: #a0a0a0;
      --border: #404040;
      --accent: #60a5fa;
      --accent-hover: #3b82f6;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      background-color: var(--bg-primary);
      color: var(--text-primary);
      line-height: 1.6;
      transition: background-color 0.3s, color 0.3s;
    }

    a {
      color: var(--accent);
      text-decoration: none;
    }

    button {
      font-family: inherit;
      cursor: pointer;
      border: none;
      background: none;
    }
  </style>

  <script>
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    const savedMode = localStorage.getItem('darkMode');
    const darkMode = savedMode !== null ? savedMode === 'true' : prefersDark;
    
    if (darkMode) {
      document.documentElement.classList.add('dark');
    }
  </script>
</head>
<body>
  <header class="reader-header">
    <div class="header-content">
      <div class="header-left">
        <a href={`/novels/${slug}`} class="back-btn">← Back</a>
        <span class="novel-title">{novel.title}</span>
      </div>
      <div class="header-right">
        <button class="icon-btn" id="dark-mode-toggle">🌙</button>
        <button class="icon-btn" id="font-decrease">A-</button>
        <button class="icon-btn" id="font-increase">A+</button>
        <button class="icon-btn" id="settings-btn">⚙️</button>
      </div>
    </div>
    
    <div class="batch-info">
      <span>Reading: <strong>Chapters {batchStart}-{batchEnd}</strong> ({chapters.length} chapters, ~{Math.round(totalWords / 250)} min)</span>
    </div>
  </header>

  <article role="main" itemscope itemtype="https://schema.org/Article" lang={novel.language}>
    <div class="reader-content">
      {chapters.map(chapter => (
        <section itemprop="articleBody" class="chapter-section">
          <h2 class="chapter-title">{chapter.title}</h2>
          <div class="chapter-body" set:html={sanitizeChapterHTML(chapter.body)} />
        </section>
      ))}
    </div>
  </article>

  <nav class="bottom-nav">
    <a 
      href={hasPrev ? `/novels/${slug}/read?start=${prevBatchStart}&mode=${modeParam}&size=${batchSize}` : '#'}
      class={`nav-btn ${!hasPrev ? 'disabled' : ''}`}
      aria-disabled={!hasPrev}
    >
      ← Previous Batch
    </a>
    <div class="progress-info">
      Chapters {batchStart}-{batchEnd} of {novel.totalChapters}
    </div>
    <a 
      href={hasNext ? `/novels/${slug}/read?start=${nextBatchStart}&mode=${modeParam}&size=${batchSize}` : '#'}
      class={`nav-btn primary ${!hasNext ? 'disabled' : ''}`}
      aria-disabled={!hasNext}
    >
      Next Batch ({nextBatchStart}-{Math.min(nextBatchStart + batchSize - 1, novel.totalChapters)}) →
    </a>
  </nav>

  <style>
    .reader-header {
      position: sticky;
      top: 0;
      background: var(--bg-primary);
      border-bottom: 2px solid var(--border);
      z-index: 100;
    }

    .header-content {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 20px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .back-btn {
      padding: 6px 12px;
      border: 1px solid var(--border);
      border-radius: 6px;
      transition: background-color 0.2s;
    }

    .back-btn:hover {
      background: var(--bg-secondary);
    }

    .novel-title {
      font-weight: 600;
    }

    .header-right {
      display: flex;
      gap: 8px;
    }

    .icon-btn {
      padding: 6px 10px;
      border: 1px solid var(--border);
      border-radius: 6px;
      background: var(--bg-primary);
      color: var(--text-primary);
      font-size: 0.9em;
      transition: background-color 0.2s;
    }

    .icon-btn:hover {
      background: var(--bg-secondary);
    }

    .batch-info {
      padding: 8px 20px;
      background: var(--bg-secondary);
      text-align: center;
      font-size: 0.9em;
      color: var(--text-secondary);
    }

    .reader-content {
      max-width: 800px;
      margin: 0 auto;
      padding: 40px 20px;
    }

    .chapter-section {
      margin-bottom: 48px;
      padding-bottom: 48px;
      border-bottom: 2px solid var(--border);
    }

    .chapter-section:last-child {
      border-bottom: none;
    }

    .chapter-title {
      font-size: 1.8em;
      margin-bottom: 24px;
      color: var(--text-primary);
    }

    .chapter-body {
      font-size: 16px;
      line-height: 1.8;
    }

    .chapter-body p {
      margin-bottom: 16px;
    }

    .chapter-body h1 {
      font-size: 1.5em;
      margin: 24px 0 16px;
    }

    .bottom-nav {
      position: sticky;
      bottom: 0;
      background: var(--bg-primary);
      border-top: 2px solid var(--border);
      padding: 16px 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      max-width: 1200px;
      margin: 0 auto;
    }

    .nav-btn {
      padding: 12px 24px;
      border-radius: 6px;
      font-weight: 600;
      transition: background-color 0.2s, transform 0.2s;
      border: 2px solid var(--border);
    }

    .nav-btn.primary {
      background: var(--accent);
      color: white;
      border-color: var(--accent);
    }

    .nav-btn.primary:hover:not(.disabled) {
      background: var(--accent-hover);
      transform: translateY(-2px);
    }

    .nav-btn:hover:not(.disabled) {
      background: var(--bg-secondary);
      transform: translateY(-2px);
    }

    .nav-btn.disabled {
      opacity: 0.5;
      cursor: not-allowed;
      pointer-events: none;
    }

    .progress-info {
      font-size: 0.9em;
      color: var(--text-secondary);
    }

    @media (max-width: 768px) {
      .header-content {
        flex-direction: column;
        gap: 12px;
      }

      .bottom-nav {
        flex-direction: column;
        gap: 12px;
      }

      .nav-btn {
        width: 100%;
        text-align: center;
      }
    }
  </style>

  <script>
    const darkModeToggle = document.getElementById('dark-mode-toggle');
    const fontDecrease = document.getElementById('font-decrease');
    const fontIncrease = document.getElementById('font-increase');
    
    darkModeToggle?.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('darkMode', String(isDark));
    });

    let fontSize = parseInt(localStorage.getItem('fontSize') || '16', 10);
    const readerContent = document.querySelector('.reader-content') as HTMLElement;
    
    function updateFontSize() {
      if (readerContent) {
        readerContent.style.fontSize = `${fontSize}px`;
        localStorage.setItem('fontSize', String(fontSize));
      }
    }
    
    fontDecrease?.addEventListener('click', () => {
      if (fontSize > 14) {
        fontSize -= 2;
        updateFontSize();
      }
    });
    
    fontIncrease?.addEventListener('click', () => {
      if (fontSize < 24) {
        fontSize += 2;
        updateFontSize();
      }
    });
    
    updateFontSize();

    const slug = window.location.pathname.split('/')[2];
    const progressKey = `novel-progress:${slug}`;
    const currentChapter = parseInt(document.querySelector('.batch-info')?.textContent?.match(/Chapters (\d+)/)?.[1] || '1', 10);
    
    let saveTimeout: number;
    function saveProgress() {
      clearTimeout(saveTimeout);
      saveTimeout = window.setTimeout(() => {
        localStorage.setItem(progressKey, JSON.stringify({
          slug,
          lastChapter: currentChapter,
          lastUpdated: Date.now()
        }));
      }, 10000);
    }
    
    saveProgress();
  </script>
</body>
</html>
