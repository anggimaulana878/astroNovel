---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import LastReadCard from '../components/LastReadCard.astro';
import NovelCard from '../components/NovelCard.astro';
import ReadingHistoryMenu from '../components/ReadingHistoryMenu.astro';
import { getAllNovels } from '../lib/novel-loader';

const novels = await getAllNovels();
---

<Layout title="AstroNovel - My Novel Library" description="Personal web novel reader">
  <main class="container">
    <header class="page-header">
      <h1>My Novel Library</h1>
      <div class="header-actions">
        <a href="/migrate" class="migrate-link" aria-label="Migration Tool">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          <span>Migrate</span>
        </a>
        <ReadingHistoryMenu novels={novels} />
      </div>
    </header>

    <LastReadCard novels={novels} />
    
    <div class="novel-grid">
      {novels.map(novel => (
        <NovelCard novel={novel} />
      ))}
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 12px 24px;
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }

  .page-header h1 {
    font-size: 1.6em;
    font-weight: 700;
    line-height: 1.15;
    min-width: 0;
    flex: 1;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .migrate-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 12px 20px;
    min-height: 44px;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: var(--bg-primary);
    color: var(--text-primary);
    font-weight: 500;
    font-size: 0.875rem;
    text-decoration: none;
    transition: background-color 0.2s;
  }

  .migrate-link:hover {
    background: var(--bg-secondary);
    color: var(--text-primary);
  }

  .migrate-link span {
    display: none;
  }

  .novel-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  @media (min-width: 768px) {
    .container {
      padding: 40px 20px;
    }

    .page-header {
      margin-bottom: 32px;
      gap: 12px;
    }

    .page-header h1 {
      font-size: 2em;
      flex: initial;
    }

    .novel-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 24px;
    }
  }

  @media (max-width: 420px) {
    .container {
      padding: 14px 10px 20px;
    }

    .page-header {
      margin-bottom: 12px;
      gap: 8px;
    }

    .page-header h1 {
      font-size: 1.2em;
    }

    .novel-grid {
      gap: 8px;
    }
  }
</style>
