---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import BannerCarousel from '../components/BannerCarousel.astro';
import LastReadCard from '../components/LastReadCard.astro';
import NovelGridCard from '../components/NovelGridCard.astro';
import { getAllNovels } from '../lib/novel-loader';

const novels = await getAllNovels();

const banners = [
  {
    title: "The Beginning After the End",
    image: novels[0]?.coverImage || "/novels/beginning-after-the-end/cover.webp",
    badge: "Editor's Choice",
    badgeColor: "primary",
    link: `/novels/${novels[0]?.slug || '#'}`,
  },
  {
    title: "Omniscient Reader's Viewpoint",
    image: novels[1]?.coverImage || "/novels/omniscient-reader/cover.webp",
    badge: "Trending",
    badgeColor: "secondary",
    link: `/novels/${novels[1]?.slug || '#'}`,
  },
  {
    title: "Solo Leveling",
    image: novels[2]?.coverImage || "/novels/solo-leveling/cover.webp",
    badge: "New Arrival",
    badgeColor: "tertiary",
    link: `/novels/${novels[2]?.slug || '#'}`,
  },
];

const ratings: Record<string, number> = {
  'beginning-after-the-end': 4.8,
  'omniscient-reader': 4.7,
  'solo-leveling': 4.9,
};

const tabLabels = ['Library', 'Fantasy', 'Romance', 'Action'];
---

<Layout title="RuangBaca — Your Novel Library" description="Personal web novel reader">

<!-- Top App Bar -->
<header class="fixed top-0 w-full z-50 bg-surface/80 backdrop-blur-xl border-b border-outline-variant/20 flex items-center justify-between px-container-margin h-16">
  <div class="flex items-center gap-2">
    <span class="material-symbols-outlined text-primary text-2xl" style="font-variation-settings: 'FILL' 1;">menu_book</span>
    <h1 class="font-display-lg text-primary leading-none">RuangBaca</h1>
  </div>
  <div class="flex items-center gap-sm">
    <button class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors">
      <span class="material-symbols-outlined text-on-surface-variant text-[22px]">search</span>
    </button>
    <a href="/migrate" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors">
      <span class="material-symbols-outlined text-on-surface-variant text-[22px]">drive_file_move</span>
    </a>
    <a href="/history" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface-container-high transition-colors">
      <span class="material-symbols-outlined text-on-surface-variant text-[22px]">history</span>
    </a>
  </div>
</header>

<main class="pt-16 pb-24 max-w-[680px] mx-auto px-container-margin">

  <!-- Banner Carousel -->
  <section class="mb-lg">
    <BannerCarousel banners={banners} />
  </section>

  <!-- Continue Reading -->
  <section class="mb-lg">
    <LastReadCard novels={novels} />
  </section>

  <!-- Sticky Tabs -->
  <nav class="sticky top-16 z-40 bg-surface/95 backdrop-blur-md -mx-container-margin px-container-margin py-3 mb-md">
    <div class="flex gap-lg overflow-x-auto no-scrollbar items-center">
      {tabLabels.map((label, i) => (
        <button
          class={`flex-none font-label-caps whitespace-nowrap ${
            i === 0
              ? 'border-b-2 pb-1 text-primary border-primary'
              : 'text-on-surface-variant'
          }`}
          data-tab={label.toLowerCase()}
        >
          {label}
        </button>
      ))}
    </div>
  </nav>

  <!-- Novel Grid -->
  <div class="grid grid-cols-3 gap-x-3 gap-y-6">
    {novels.map((novel) => (
      <NovelGridCard
        novel={novel}
        rating={ratings[novel.slug] || 4.5}
      />
    ))}
  </div>

</main>

<script>
  const tabs = document.querySelectorAll('nav.sticky button');
  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => {
        t.classList.remove('text-primary', 'border-primary');
        t.classList.add('text-on-surface-variant');
      });
      tab.classList.add('text-primary', 'border-primary');
      tab.classList.remove('text-on-surface-variant');
    });
  });
</script>

</Layout>
