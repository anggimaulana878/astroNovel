---
export const prerender = true;

import Layout from '../layouts/Layout.astro';
import LastReadCard from '../components/LastReadCard.astro';
import NovelCard from '../components/NovelCard.astro';
import ReadingHistoryMenu from '../components/ReadingHistoryMenu.astro';
import { getAllNovels } from '../lib/novel-loader';

const novels = await getAllNovels();
---

<Layout title="AstroNovel - My Novel Library" description="Personal web novel reader">
  <main class="container">
    <header class="page-header">
      <h1>My Novel Library</h1>
      <ReadingHistoryMenu novels={novels} />
    </header>

    <LastReadCard novels={novels} />
    
    <div class="novel-grid">
      {novels.map(novel => (
        <NovelCard novel={novel} />
      ))}
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 16px 12px 24px;
  }

  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }

  .page-header h1 {
    font-size: 1.6em;
    font-weight: 700;
    line-height: 1.15;
    min-width: 0;
    flex: 1;
  }

  .novel-grid {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  @media (min-width: 768px) {
    .container {
      padding: 40px 20px;
    }

    .page-header {
      margin-bottom: 32px;
      gap: 12px;
    }

    .page-header h1 {
      font-size: 2em;
      flex: initial;
    }

    .novel-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 24px;
    }
  }

  @media (max-width: 420px) {
    .container {
      padding: 14px 10px 20px;
    }

    .page-header {
      margin-bottom: 12px;
      gap: 8px;
    }

    .page-header h1 {
      font-size: 1.2em;
    }

    .novel-grid {
      gap: 8px;
    }
  }
</style>
